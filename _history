shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"argument_reporter_number\"><field name=\"VALUE\">y</field></block></value><value name=\"B\"><shadow type=\"math_number\"><field name=\"NUM\">1</field></shadow></value></block></value></block></statement><next><block type=\"device_pause\"><value name=\"pause\"><shadow type=\"timePicker\"><field name=\"ms\">80</field></shadow></value></block></next></block></next></block></next></block></next></block></next></block></next></block></statement></block></xml>","main.ts":"let player = 2\n\nlet bulletX = 0\nlet bulletY = 0\nlet bulletActive = false\n\nlet enemyX = randint(0, 4)\nlet enemyY = 0\n\nlet speed = 600\nlet score = 0\n\n// BOSS\nlet bossX = 2\nlet bossY = 0\nlet bossActive = false\nlet bossTeleport = 0\nlet bossVulnerable = false\n\nlet bossBulletX = 0\nlet bossBulletY = 0\nlet bossBulletActive = false\n\nfunction explosion(x: number, y: number) {\n\n    led.plot(x, y)\n    basic.pause(40)\n\n    if (x > 0) led.plot(x - 1, y)\n    if (x < 4) led.plot(x + 1, y)\n    if (y > 0) led.plot(x, y - 1)\n    if (y < 4) led.plot(x, y + 1)\n\n    basic.pause(80)\n}\n\nbasic.forever(function () {\n\n    basic.clearScreen()\n\n    led.plot(player, 4)\n\n    // tiro\n    if (bulletActive) {\n\n        led.plot(bulletX, bulletY)\n\n        bulletY += -1\n\n        if (bulletY < 0) bulletActive = false\n    }\n\n    // ativar boss\n    if (score >= 100 && !bossActive) {\n\n        basic.showString(\"BOSS\")\n\n        bossActive = true\n        bossTeleport = 0\n    }\n\n    // INIMIGO NORMAL\n    if (!bossActive) {\n\n        if (enemyY >= 0) led.plot(enemyX, enemyY)\n\n        enemyY += 1\n\n        if (bulletActive && bulletX == enemyX && bulletY == enemyY) {\n\n            explosion(enemyX, enemyY)\n\n            score += 1\n\n            enemyX = randint(0, 4)\n            enemyY = 0\n\n            bulletActive = false\n        }\n\n        if (enemyY == 4 && enemyX == player) {\n\n            basic.showString(\"END\")\n            basic.showNumber(score)\n\n            control.reset()\n        }\n\n        if (enemyY > 4) {\n\n            enemyX = randint(0, 4)\n            enemyY = 0\n        }\n    }\n\n    // BOSS\n    if (bossActive) {\n\n        led.plot(bossX, bossY)\n\n        if (randint(0, 10) == 0 && bossTeleport < 3) {\n\n            bossX = randint(0, 4)\n            bossTeleport += 1\n        }\n\n        if (bossTeleport >= 3) bossVulnerable = true\n\n        // tiro boss\n        if (!bossBulletActive && randint(0, 4) == 0) {\n\n            bossBulletActive = true\n            bossBulletX = bossX\n            bossBulletY = bossY\n        }\n\n        if (bossBulletActive) {\n\n            led.plot(bossBulletX, bossBulletY)\n\n            bossBulletY += 1\n\n            if (bossBulletY == 4 && bossBulletX == player) {\n\n                basic.showString(\"END\")\n                basic.showNumber(score)\n\n                control.reset()\n            }\n\n            if (bossBulletY > 4) bossBulletActive = false\n        }\n\n        // matar boss\n        if (bossVulnerable && bulletActive && bulletX == bossX && bulletY == bossY) {\n\n            basic.showString(\"WIN\")\n\n            score += 50\n\n            bossActive = false\n        }\n    }\n\n    basic.pause(speed)\n\n})\n\ninput.onButtonPressed(Button.A, function () {\n\n    player += -1\n    if (player < 0) player = 0\n})\n\ninput.onButtonPressed(Button.B, function () {\n\n    player += 1\n    if (player > 4) player = 4\n})\n\ninput.onButtonPressed(Button.AB, function () {\n\n    if (!bulletActive) {\n\n        bulletActive = true\n        bulletX = player\n        bulletY = 3\n    }\n})","README.md":"","pxt.json":"{\n    \"name\": \"blocks\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1773257967166,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"Geoz:vY-OP-M(KDGoB:9\">player</variable><variable id=\"WLpb#wQAQXWS38134,pY\">bulletActive</variable><variable id=\"gG)eVII#57Rb)G{bSTKS\">bulletX</variable><variable id=\"ikHD{IX1*hJc:?CsPi{]\">bulletY</variable><variable id=\"XylFS44Avv``1+L.3sUO\">score</variable><variable id=\"|da3hRGqKtAXAYQFxR5a\">bossActive</variable><variable id=\"92pZEWEovg0@oLKAWpDT\">bossTeleport</variable><variable id=\"iiG8O@!oo8hov;;[JZT~\">enemy1Y</variable><variable id=\"BM0A#|WF[$kBs!-wA,gY\">enemy1X</variable><variable id=\"O.MpcmlzaLH?bWo*q3zd\">enemy2Y</variable><variable id=\"v}C*J6%=PUeYQrdg+;P^\">enemy2X</variable><variable id=\"(:^if[mdSh/Y@,VC@QM-\">enemy3Y</variable><variable id=\"7WAzEoa[R1qR[k_-SIT7\">enemy3X</variable><variable id=\"F^uD4O(UwpdeSw!tbG0T\">speed</variable><variable id=\"2UG$eSN+UYAek?e$QX6w\">bossX</variable><variable id=\"vhc=TA96MZsfLk5)_@$6\">bossY</variable><variable id=\"0j7TFI[H:)v}oPT8xda|\">bossVulnerable</variable><variable id=\"kjjGZ,:ia!:Ci-X`OjiC\">bossBulletActive</variable><variable id=\"YyP7kT/`YWtRx3dV*8-;\">bossBulletX</variable><variable id=\"k/$Ql_+gjd%bt*XVK`#*\">bossBulletY</variable></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"Geoz:vY-OP-M(KDGoB:9\">player</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">2</field></shadow></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"BM0A#|WF[$kBs!-wA,gY\">enemy1X</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow><block type=\"device_random\"><value name=\"min\"><shadow type=\"math_number\"><field name=\"NUM\">0</field></shadow></value><value name=\"limit\"><shadow type=\"math_number\"><field name=\"NUM\">4</